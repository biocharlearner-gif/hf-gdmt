VITE_SMART_ISS=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
VITE_SMART_CLIENT_ID=<your_epic_client_id>
VITE_SMART_REDIRECT_URI=http://localhost:5173/callback
VITE_SMART_SCOPE=openid fhirUser patient/Patient.read patient/Condition.read patient/Observation.read patient/MedicationRequest.read patient/AllergyIntolerance.read patient/Encounter.read patient/Task.write patient/ServiceRequest.write patient/CarePlan.write

# Optional: separate writable FHIR server (HAPI/Medplum) if Epic rejects creates.
# Defaults to VITE_SMART_ISS (single-vendor Epic mode) when unset.
# VITE_FHIR_WRITE_BASE=

# ---------------------------------------------------------------------------
# Backend-for-frontend (server/index.ts, run with `npm run server`).
# These are SERVER-ONLY and must NOT be VITE_-prefixed (Vite inlines VITE_* into
# the client bundle). Put real values in .env.local (git-ignored) — NEVER here.
# ---------------------------------------------------------------------------

# Tenant FHIR base URL. Defaults to public HAPI (unauthenticated) when unset.
MEDBLOCKS_FHIR_BASE=https://fhir.medblocks.com/fhir/<tenant-id>

# Tenant Bearer token — the BFF injects this server-side; it never reaches the
# browser. Leave blank to run the proxy against an unauthenticated server (HAPI).
MEDBLOCKS_TOKEN=

# Where the SPA is hosted, used to build CDS Hooks launch links.
SMART_APP_URL=http://localhost:5173

# BFF listen port.
PORT=8787

# Anthropic API key for the RAG cited-explanation endpoint (/api/rationale). SERVER-ONLY
# — never VITE_-prefixed. When unset, the endpoint returns deterministic cited
# explanations (retrieval + engine facts) so the demo still works; set it to enable the
# grounded LLM prose. Put the real key in .env.local (local/Bun) and in the Vercel
# project env (production).
ANTHROPIC_API_KEY=

# Optional model override for the rationale endpoint. Defaults to claude-opus-4-8.
# Set to a cheaper model (e.g. claude-haiku-4-5 or claude-sonnet-5) to cut cost.
ANTHROPIC_MODEL=
