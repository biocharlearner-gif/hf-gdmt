{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/fhir/:_vpath*", "destination": "/api/fhir-proxy?__path=:_vpath*" },
    { "source": "/cds-services", "destination": "/api/cds-services" },
    { "source": "/cds-services/:service", "destination": "/api/cds-services/:service" },
    { "source": "/notify", "destination": "/api/notify" },
    { "source": "/health", "destination": "/api/health" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
